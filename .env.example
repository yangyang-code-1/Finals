APP_ENV=prod
APP_SECRET=change_me

DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE?serverVersion=8.0.32&charset=utf8mb4"
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

MAILER_FROM_ADDRESS=you@example.com
MAILER_FROM_NAME="Comms"
CONTACT_NOTIFY_EMAIL=you@example.com
MAILER_DSN=smtp://USER:PASSWORD@HOST:587

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me

CORS_ALLOW_ORIGIN='^https?://.*$'
