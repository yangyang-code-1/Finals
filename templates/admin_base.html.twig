{# templates/admin_base.html.twig #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{% block title %}Admin Dashboard{% endblock %}</title>

  <!-- Bootstrap + Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  <!-- DataTables -->
  <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet">

  <style>
    :root{
      --primary-color: #4b0082;
      --accent: #7c3aed;
      --accent-soft: #c084fc;
      --bg-light: #f9f5ff;
      --ink: #2a124b;
      --muted: #6b5f80;
      --white: #fff;
      --shadow: 0 18px 50px rgba(42,18,75,0.08);
      --radius: 22px;
    }
    html,body{height:100%}
    body{
      font-family:'Inter','Segoe UI',system-ui,sans-serif;
      background:
        radial-gradient(circle at 8% 0%, rgba(192,132,252,0.16), transparent 28%),
        linear-gradient(180deg,#fdfbff 0%,var(--bg-light) 100%);
      margin:0;
      display:flex;
      min-height:100vh;
      color:var(--ink);
      overflow-x:hidden;
    }

    .sidebar{
      width:282px;
      color:#fff;
      padding:1rem;
      position:fixed;
      top:0.85rem;bottom:0.85rem;left:0.85rem;
      z-index:1000;
      transition:width .28s ease, transform .28s ease;
      overflow:auto;
      border-radius:28px;
      background:
        radial-gradient(circle at 20% 10%, rgba(255,255,255,0.22), transparent 25%),
        linear-gradient(160deg,#2a124b 0%,#4b0082 48%,#7c3aed 100%);
      box-shadow:0 28px 70px rgba(42,18,75,0.24);
    }
    .sidebar.collapsed{width:88px}
    .sidebar .brand{
      display:flex;
      align-items:center;
      margin-bottom:1rem;
      padding:.45rem .35rem 1rem;
      border-bottom:1px solid rgba(255,255,255,0.14);
      white-space:nowrap;
    }
    .sidebar .brand img{
      width:148px;
      height:56px;
      object-fit:contain;
      filter:drop-shadow(0 10px 18px rgba(0,0,0,0.18));
    }
    .sidebar.collapsed .brand{justify-content:center;padding-left:0;padding-right:0}
    .sidebar.collapsed .brand img{width:54px;height:42px}

    .sidebar nav a{
      display:flex;
      align-items:center;
      gap:.75rem;
      padding:.78rem .72rem;
      border-radius:16px;
      color:rgba(255,255,255,0.9);
      text-decoration:none;
      margin-bottom:.28rem;
      font-weight:850;
      transition:all .18s ease;
      border:1px solid transparent;
    }
    .sidebar nav a:hover,
    .sidebar nav a.active{
      background:rgba(255,255,255,0.16);
      border-color:rgba(255,255,255,0.16);
      color:#fff;
      transform:translateX(3px);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05);
    }
    .sidebar nav a i{
      font-size:1.12rem;
      width:24px;
      text-align:center;
      flex:none;
    }
    .sidebar .submenu{
      padding-left:.55rem;
      margin:.25rem 0 .55rem .7rem;
      border-left:1px solid rgba(255,255,255,0.16);
      display:block;
    }
    .sidebar .submenu a{
      padding:.62rem .7rem;
      font-size:.9rem;
      opacity:.92;
    }
    .sidebar.collapsed .submenu,
    .sidebar.collapsed .label-text,
    .sidebar.collapsed .sidebar-footer{display:none}
    .sidebar .badge{
      border-radius:999px;
      font-weight:900;
      padding:.34rem .52rem;
    }
    .sidebar-footer{
      margin-top:1.25rem;
      padding:.9rem;
      border-radius:20px;
      background:rgba(255,255,255,0.12);
      border:1px solid rgba(255,255,255,0.14);
      font-size:.86rem;
      color:rgba(255,255,255,0.88);
    }

    .content{
      margin-left:306px;
      flex:1;
      padding:1.25rem 1.45rem 2rem;
      transition:margin-left .28s ease;
      min-width:0;
    }
    .collapsed + .content{margin-left:112px}

    .topbar{
      position:sticky;
      top:0;
      z-index:900;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:1rem;
      margin-bottom:1.25rem;
      padding:.85rem 1rem;
      border-radius:24px;
      background:rgba(255,255,255,0.88);
      border:1px solid rgba(124,58,237,0.12);
      box-shadow:var(--shadow);
      backdrop-filter:blur(18px);
    }
    .sidebar-toggle{
      width:42px;height:42px;
      display:grid;place-items:center;
      border-radius:14px;
      color:var(--primary-color);
      background:rgba(124,58,237,0.08);
      cursor:pointer;
      transition:transform .15s ease,background .15s ease;
    }
    .sidebar-toggle:hover{transform:translateY(-1px);background:rgba(124,58,237,0.14)}
    .topbar h4{font-weight:950;color:var(--ink);letter-spacing:-.02em}
    .search-input{
      background:#fff;
      border:1px solid rgba(124,58,237,0.12);
      border-radius:999px;
      padding:.5rem .85rem;
      box-shadow:0 10px 25px rgba(42,18,75,0.06);
    }
    .search-input input{background:transparent;box-shadow:none}
    .admin-icon-btn{
      width:42px;height:42px;
      display:grid;place-items:center;
      border-radius:14px;
      color:var(--primary-color);
      background:#fff;
      border:1px solid rgba(124,58,237,0.12);
      text-decoration:none;
      box-shadow:0 10px 25px rgba(42,18,75,0.06);
    }
    .admin-user-button{
      display:flex;
      align-items:center;
      gap:.6rem;
      padding:.38rem .55rem .38rem .38rem;
      border-radius:999px;
      color:var(--ink);
      background:#fff;
      border:1px solid rgba(124,58,237,0.12);
      text-decoration:none;
      box-shadow:0 10px 25px rgba(42,18,75,0.06);
    }
    .admin-user-avatar{
      width:36px;height:36px;
      display:grid;place-items:center;
      border-radius:50%;
      color:#fff;
      background:linear-gradient(135deg,var(--accent),var(--accent-soft));
      font-weight:950;
    }
    .admin-user-meta strong{display:block;font-size:.88rem;line-height:1;color:var(--ink)}
    .admin-user-meta small{display:block;margin-top:.18rem;color:var(--muted);font-size:.72rem;font-weight:800}
    .dropdown-menu{
      border:1px solid rgba(124,58,237,0.12);
      border-radius:18px;
      box-shadow:0 20px 50px rgba(42,18,75,0.14);
      padding:.55rem;
    }
    .dropdown-item{
      border-radius:12px;
      padding:.7rem .85rem;
      font-weight:800;
      color:var(--ink);
    }
    .dropdown-item:hover{
      background:var(--bg-light);
      color:var(--accent);
    }
    .realtime-toast{
      position:fixed;
      right:1rem;
      bottom:1rem;
      z-index:2000;
      max-width:min(360px, calc(100vw - 2rem));
      padding:1rem;
      border-radius:18px;
      color:#fff;
      background:linear-gradient(135deg,#4b0082,#7c3aed);
      box-shadow:0 20px 50px rgba(42,18,75,0.25);
      font-weight:800;
      opacity:0;
      transform:translateY(12px);
      pointer-events:none;
      transition:opacity .2s ease, transform .2s ease;
    }
    .realtime-toast.show{
      opacity:1;
      transform:translateY(0);
    }

    .dashboard-eyebrow{
      display:inline-flex;
      align-items:center;
      gap:.45rem;
      padding:.4rem .75rem;
      border-radius:999px;
      background:rgba(124,58,237,0.08);
      border:1px solid rgba(124,58,237,0.14);
      color:var(--primary-color);
      font-weight:900;
      font-size:.85rem;
      margin-bottom:.75rem;
    }
    .stat-card{
      background:#fff;
      border:1px solid rgba(124,58,237,0.1);
      border-radius:20px;
      padding:1rem;
      box-shadow:var(--shadow);
      min-height:90px;
    }
    .table-container,
    .card{
      border:1px solid rgba(124,58,237,0.1);
      border-radius:22px!important;
      box-shadow:var(--shadow);
    }
    table.dataTable{background:#fff;border-radius:18px;overflow:hidden}

    @media (max-width: 980px){
      body{display:block}
      .sidebar{
        position:fixed;
        width:min(320px, calc(100vw - 1.5rem));
        top:.75rem;
        bottom:.75rem;
        left:.75rem;
        margin:0;
        border-radius:24px;
        transform:translateX(calc(-100% - 1.5rem));
        opacity:0;
        pointer-events:none;
      }
      .sidebar.mobile-open{
        transform:translateX(0);
        opacity:1;
        pointer-events:auto;
      }
      .sidebar.collapsed{width:min(320px, calc(100vw - 1.5rem))}
      .sidebar.collapsed .label-text,
      .sidebar.collapsed .sidebar-footer{display:block}
      .sidebar.collapsed .brand{justify-content:flex-start}
      .sidebar.collapsed .brand img{width:148px;height:56px}
      .content,.collapsed + .content{margin-left:0;padding:.75rem}
      .topbar{position:sticky;top:.75rem;flex-wrap:wrap}
      .search-input input{width:150px!important}
    }
    @media (max-width: 640px){
      .topbar .search-input{display:none!important}
      .admin-user-meta{display:none}
    }
  </style>

  {% block styles %}{% endblock %}
</head>
<body>
  {% set currentRoute = app.request.attributes.get('_route')|default('') %}
  <aside id="sidebar" class="sidebar">
    <div class="brand">
      <img src="/Primary Logo.png" alt="Comms logo">
    </div>

    <nav>
    {# ADMIN-ONLY: Dashboard #}
    {% if is_granted('ROLE_ADMIN') %}
      <a href="{{ path('app_admin_dashboard') }}" class="{% if currentRoute starts with 'app_admin_dashboard' %}active{% endif %}">
        <i class="bi bi-speedometer2"></i> <span class="label-text">Dashboard</span>
      </a>
    {% endif %}

    {# BOTH ADMIN AND STAFF: Commissions #}
    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
      <a href="{{ path('app_commission_index') }}" class="{% if currentRoute in ['app_commission_index', 'app_commission_new', 'app_commission_show', 'app_commission_edit'] %}active{% endif %}">
        <i class="bi bi-palette"></i> <span class="label-text">Commissions</span>
        {% if commission_count is defined and commission_count > 0 %}
          <span class="badge bg-light text-dark ms-auto">{{ commission_count }}</span>
        {% endif %}
      </a>
      <a href="{{ path('app_commission_requests') }}" class="{% if currentRoute == 'app_commission_requests' %}active{% endif %}">
        <i class="bi bi-bag-heart-fill"></i> <span class="label-text">Slot requests</span>
        {% if pending_request_count is defined and pending_request_count > 0 %}
          <span class="badge bg-warning text-dark ms-auto">{{ pending_request_count }}</span>
        {% endif %}
      </a>
      <a href="{{ path('app_commission_active') }}" class="{% if currentRoute == 'app_commission_active' %}active{% endif %}">
        <i class="bi bi-brush-fill"></i> <span class="label-text">Active work</span>
        {% if active_commission_count is defined and active_commission_count > 0 %}
          <span class="badge bg-light text-dark ms-auto">{{ active_commission_count }}</span>
        {% endif %}
      </a>
    {% endif %}

    {# BOTH ADMIN AND STAFF: Categories #}
    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
      <a href="{{ path('app_category_index') }}" class="{% if currentRoute starts with 'app_category' %}active{% endif %}">
        <i class="bi bi-folder2-open"></i> <span class="label-text">Categories</span>
        {% if category_count is defined %}
          <span class="badge bg-light text-dark ms-auto">{{ category_count }}</span>
        {% endif %}
      </a>
    {% endif %}

    {# ADMIN-ONLY: Users Section #}
    {% if is_granted('ROLE_ADMIN') %}
      <div class="mt-2">
        <a href="#" id="usersToggle" class="">
          <i class="bi bi-people"></i> <span class="label-text">Users</span>
          <i class="bi bi-caret-down-fill ms-auto label-text"></i>
        </a>
        <div class="submenu" id="usersSubmenu">
          <a href="{{ path('app_user_index', {'role': 'ROLE_ADMIN'}) }}" class="{% if currentRoute == 'app_user_index' and app.request.query.get('role') == 'ROLE_ADMIN' %}active{% endif %}">
            <i class="bi bi-person-badge"></i> <span class="label-text">Admins</span>
          </a>
          <a href="{{ path('app_user_index', {'role': 'ROLE_STAFF'}) }}" class="{% if currentRoute == 'app_user_index' and app.request.query.get('role') == 'ROLE_STAFF' %}active{% endif %}">
            <i class="bi bi-briefcase"></i> <span class="label-text">Staff</span>
            {% if staff_count is defined %}<span class="badge bg-light text-dark ms-auto">{{ staff_count }}</span>{% endif %}
          </a>
          <a href="{{ path('app_user_index', {'role': 'ROLE_USER'}) }}" class="{% if currentRoute == 'app_user_index' and app.request.query.get('role') == 'ROLE_USER' %}active{% endif %}">
            <i class="bi bi-person"></i> <span class="label-text">Users</span>
            {% if user_count is defined %}<span class="badge bg-light text-dark ms-auto">{{ user_count }}</span>{% endif %}
          </a>
        </div>
      </div>

      <a href="{{ path('app_activity_log_index') }}" class="{% if currentRoute starts with 'app_activity_log' %}active{% endif %}">
        <i class="bi bi-clock-history"></i> <span class="label-text">Activity Logs</span>
      </a>

      {# <a href="#" class="" onclick="alert('Transactions feature coming soon!')">
        <i class="bi bi-receipt"></i> <span class="label-text">Transactions</span>
        <span class="badge bg-warning text-dark ms-auto">Soon</span>
      </a>

      <a href="#" class="" onclick="alert('Reports feature coming soon!')">
        <i class="bi bi-bar-chart"></i> <span class="label-text">Reports</span>
        <span class="badge bg-warning text-dark ms-auto">Soon</span>
      </a>

      <a href="#" class="" onclick="alert('Settings feature coming soon!')">
        <i class="bi bi-gear"></i> <span class="label-text">Settings</span>
        <span class="badge bg-warning text-dark ms-auto">Soon</span>
      </a> #}
    {% endif %}
    </nav>

    <div class="sidebar-footer">
      <div class="label-text">Signed in as</div>
      <strong>{{ app.user ? (app.user.name ?? 'Staff') : 'Staff' }}</strong>
    </div>
  </aside>

  <main id="content" class="content">
    <div class="topbar">
      <div class="d-flex align-items-center gap-3">
        <span class="sidebar-toggle" id="sidebarToggle"><i class="bi bi-list" style="font-size:1.35rem;"></i></span>
        <h4 class="mb-0">{% block header %}Dashboard{% endblock %}</h4>
      </div>

      <div class="d-flex align-items-center gap-2">
        <div class="search-input d-flex align-items-center gap-2">
          <i class="bi bi-search"></i>
          <input class="form-control border-0 p-0" style="width:220px" placeholder="Search..." />
        </div>

        <div class="position-relative">
          <a href="{{ path('app_commission_requests') }}" class="admin-icon-btn" title="Slot requests">
            <i class="bi bi-bell"></i>
          </a>
          {% set slot_request_notifications = notifications_count|default(pending_request_count|default(0)) %}
          {% if slot_request_notifications > 0 %}
            <span class="badge bg-danger position-absolute top-0 start-100 translate-middle p-1 rounded-circle"></span>
          {% endif %}
        </div>

        <div class="dropdown">
          <a class="admin-user-button" href="#" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="admin-user-avatar">{{ app.user ? app.user.name|default('S')|slice(0, 1)|upper : 'S' }}</span>
            <span class="admin-user-meta">
              <strong>{{ app.user ? app.user.name|default('Staff') : 'Staff' }}</strong>
              <small>{{ is_granted('ROLE_ADMIN') ? 'Administrator' : 'Staff' }}</small>
            </span>
            <i class="bi bi-chevron-down small"></i>
          </a>
          <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
            <li><a class="dropdown-item" href="{{ path('app_account') }}">
              <i class="bi bi-person-circle me-2"></i>Profile
            </a></li>
            <li><a class="dropdown-item" href="{{ path('app_commissions_browse') }}">
              <i class="bi bi-window-sidebar me-2"></i>Public site
            </a></li>
            <li><a class="dropdown-item" href="{{ path('app_commission_requests') }}">
              <i class="bi bi-bag-heart me-2"></i>Slot requests
            </a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="{{ path('app_logout') }}">
              <i class="bi bi-box-arrow-right me-2"></i>Logout
            </a></li>
          </ul>
        </div>
      </div>
    </div>

    <div>
      {% block body %}
      {# Default dashboard body: quick stats + recent commissions #}
      <div class="row g-3 mb-3">
        <div class="col-md-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="small-muted">Total Commissions</div>
                <div style="font-weight:700;font-size:1.15rem">{{ commission_count|default(0) }}</div>
              </div>
              <i class="bi bi-palette" style="font-size:1.7rem;color:var(--accent)"></i>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="small-muted">Staff</div>
                <div style="font-weight:700">{{ staff_count|default(0) }}</div>
              </div>
              <i class="bi bi-briefcase" style="font-size:1.7rem;color:var(--accent)"></i>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="small-muted">Users</div>
                <div style="font-weight:700">{{ user_count|default(0) }}</div>
              </div>
              <i class="bi bi-person" style="font-size:1.7rem;color:var(--accent)"></i>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="small-muted">Categories</div>
                <div style="font-weight:700">{{ category_count|default(0) }}</div>
              </div>
              <i class="bi bi-folder2-open" style="font-size:1.7rem;color:var(--accent)"></i>
            </div>
          </div>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-body">
          <h5 class="card-title">Recent Commissions</h5>
          <div class="table-responsive">
            <table id="commissionsTable" class="table table-striped table-hover">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Title</th>
                  <th>Client</th>
                  <th>Artist</th>
                  <th>Status</th>
                  <th>Created</th>
                </tr>
              </thead>
              <tbody>
                {% for c in recent_commissions|default([]) %}
                  <tr>
                    <td>{{ loop.index }}</td>
                    <td>{{ c.title }}</td>
                    <td>{{ c.client ? c.client.name : '—' }}</td>
                    <td>{{ c.artist ? c.artist.name : '—' }}</td>
                    <td>{{ c.status }}</td>
                    <td>{{ c.createdAt ? c.createdAt|date('Y-m-d H:i') : '—' }}</td>
                  </tr>
                {% else %}
                  <tr><td colspan="6" class="text-center">No recent commissions</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>
      {% endblock %}
    </div>
  </main>

  <!-- JS -->
  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <!-- DataTables -->
  <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
  <script src="https://cdn.socket.io/4.8.1/socket.io.min.js"></script>

  <script>
    // toggle sidebar collapse
    const sidebar = document.getElementById('sidebar');
    const sidebarToggle = document.getElementById('sidebarToggle');
    function isMobileAdminLayout() {
      return window.matchMedia('(max-width: 980px)').matches;
    }

    function closeMobileSidebar() {
      sidebar.classList.remove('mobile-open');
    }

    sidebarToggle.addEventListener('click', () => {
      if (isMobileAdminLayout()) {
        sidebar.classList.toggle('mobile-open');
        return;
      }

      sidebar.classList.toggle('collapsed');
      document.getElementById('content').classList.toggle('collapsed');
    });

    document.addEventListener('click', (event) => {
      if (!isMobileAdminLayout() || !sidebar.classList.contains('mobile-open')) return;
      if (sidebar.contains(event.target) || sidebarToggle.contains(event.target)) return;
      closeMobileSidebar();
    });

    sidebar.querySelectorAll('a[href]').forEach((link) => {
      link.addEventListener('click', () => {
        if (isMobileAdminLayout()) closeMobileSidebar();
      });
    });

    window.addEventListener('resize', () => {
      if (!isMobileAdminLayout()) closeMobileSidebar();
    });

    // users submenu toggle
    const usersToggle = document.getElementById('usersToggle');
    const usersSubmenu = document.getElementById('usersSubmenu');
    if (usersToggle && usersSubmenu) {
      usersToggle.addEventListener('click', (e) => {
        e.preventDefault();
        usersSubmenu.classList.toggle('d-none');
      });
    }

    // datatable init (tables that exist)
    //$(document).ready(function(){
    //  if (document.getElementById('commissionsTable')) {
    //    $('#commissionsTable').DataTable({
    //    pageLength:5,
    //    lengthMenu:[5,10,25],
    //    language:{search: "🔍 Search:"}
    //    });
    //  }
    //  if (document.getElementById('recentCommissionsTable')) {
    //    $('#recentCommissionsTable').DataTable({
    //      pageLength:5,
    //      lengthMenu:[5,10,25],
    //      language:{search: "🔍 Search:"}
    //    });
    //  }
    //}); 
    // DUPLICATE NI
  </script>

  <script>
    (function () {
      const realtimeUrl = 'https://websocket-production-93ef.up.railway.app';

      if (!window.io) {
        console.warn('Socket.IO client was not loaded.');
        return;
      }

      const toast = document.createElement('div');
      toast.className = 'realtime-toast';
      document.body.appendChild(toast);

      function showRealtimeToast(message) {
        toast.textContent = message;
        toast.classList.add('show');
        window.setTimeout(() => toast.classList.remove('show'), 3500);
      }

      const socket = window.io(realtimeUrl, {
        reconnectionAttempts: 5,
        timeout: 10000,
      });

      socket.on('connect', () => {
        socket.emit('join_admin_room');
        console.log('Admin realtime connected:', socket.id);
      });

      socket.on('connect_error', (error) => {
        console.warn('Admin realtime connection error:', error.message);
      });

      socket.on('commission_request_created', (data) => {
        const title = data?.title || 'Commission request';
        showRealtimeToast(`New mobile request: ${title}`);

        const refreshPaths = ['/admin', '/commission', '/commission/requests', '/commission/active'];
        if (refreshPaths.includes(window.location.pathname)) {
          window.setTimeout(() => window.location.reload(), 1200);
        }
      });

      socket.on('progress_updated', (data) => {
        const title = data?.title || 'Commission';
        const status = data?.status || 'updated';
        showRealtimeToast(`${title} is now ${status}`);

        const refreshPaths = ['/admin', '/commission', '/commission/requests', '/commission/active'];
        if (refreshPaths.includes(window.location.pathname)) {
          window.setTimeout(() => window.location.reload(), 1200);
        }
      });
    })();
  </script>

  {% block scripts %}{% endblock %}
</body>
</html>
