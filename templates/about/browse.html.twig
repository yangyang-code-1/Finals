{% extends 'public/layout.html.twig' %}

{% block title %}Browse Commissions — Comms{% endblock %}

{% block page_styles %}
<style>
  .hero-search {
    max-width: 560px;
    margin: 1.25rem auto 0;
    display: flex;
    gap: 0.5rem;
    background: rgba(255,255,255,0.95);
    padding: 0.4rem;
    border-radius: 999px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
    border: 1px solid rgba(255,255,255,0.5);
  }

  .hero-search input {
    flex: 1;
    border: none;
    background: transparent;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-weight: 650;
    outline: none;
    color: var(--ink);
  }

  .hero-search button {
    border: none;
    border-radius: 999px;
    padding: 0.75rem 1.25rem;
    font-weight: 900;
    color: #fff;
    background: linear-gradient(135deg, #7c3aed, #c084fc);
    white-space: nowrap;
  }

  .browse-toolbar {
    margin: -2rem auto 0;
    position: relative;
    z-index: 2;
    padding: 0 1.5rem;
    max-width: 1180px;
  }

  .filters {
    padding: 1.25rem;
    border-radius: 20px;
    background: var(--card);
    border: 1px solid rgba(124,58,237,0.12);
    box-shadow: 0 12px 32px rgba(124,58,237,0.08);
  }

  .filters-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .filters-top h2 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--purple-deep);
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.85rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    font-weight: 850;
    font-size: 0.88rem;
    text-decoration: none;
    color: var(--purple-deep);
    background: rgba(124,58,237,0.08);
    border: 1px solid rgba(124,58,237,0.16);
    transition: transform 0.15s ease, background 0.15s ease;
  }

  .chip:hover { transform: translateY(-1px); background: rgba(124,58,237,0.14); color: var(--purple-deep); }
  .chip.active { background: rgba(124,58,237,0.2); border-color: rgba(124,58,237,0.35); }

  .listing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.15rem;
    margin-top: 2rem;
  }

  .listing-card {
    background: var(--card);
    border-radius: 20px;
    border: 1px solid rgba(124,58,237,0.1);
    overflow: hidden;
    box-shadow: 0 8px 22px rgba(0,0,0,0.04);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .listing-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow);
  }

  .listing-thumb {
    height: 200px;
    background-size: cover;
    background-position: center;
    position: relative;
  }

  .listing-thumb::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.35));
    pointer-events: none;
  }

  .badge-open {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 1;
    background: #10b981;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.55rem;
    border-radius: 8px;
  }

  .badge-cat {
    position: absolute;
    bottom: 12px;
    left: 12px;
    z-index: 1;
    background: rgba(255,255,255,0.92);
    color: var(--purple-deep);
    font-size: 0.8rem;
    font-weight: 900;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,0.06);
  }

  .listing-body { padding: 1.1rem 1.15rem 1.2rem; }

  .listing-title {
    margin: 0 0 0.35rem;
    font-size: 1.05rem;
    font-weight: 900;
    color: var(--ink);
    line-height: 1.35;
  }

  .listing-rating {
    color: #f59e0b;
    font-size: 0.85rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .listing-desc {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: var(--muted);
    font-weight: 650;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .listing-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .listing-price { color: var(--purple-main); font-weight: 900; font-size: 1rem; }

  .listing-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.85rem;
  }

  .btn-browse {
    flex: 1;
    border-radius: 12px;
    padding: 0.55rem 0.75rem;
    font-weight: 900;
    font-size: 0.88rem;
    border: 1px solid rgba(124,58,237,0.22);
    background: rgba(124,58,237,0.06);
    color: var(--purple-deep);
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .btn-browse:hover { background: rgba(124,58,237,0.12); color: var(--purple-deep); }

  .btn-browse-solid {
    flex: 1;
    border-radius: 12px;
    padding: 0.55rem 0.75rem;
    font-weight: 900;
    font-size: 0.88rem;
    border: none;
    background: linear-gradient(135deg, #7c3aed, #c084fc);
    color: #fff;
    text-align: center;
    text-decoration: none;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 1.5rem;
    background: var(--card);
    border-radius: 20px;
    border: 1px dashed rgba(124,58,237,0.25);
  }

  .sort-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin-top: 1.5rem;
    font-weight: 800;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .sort-pill {
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(124,58,237,0.08);
    color: var(--purple-deep);
    font-weight: 850;
    font-size: 0.85rem;
  }

  @media (max-width: 992px) {
    .listing-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 576px) {
    .listing-grid { grid-template-columns: 1fr; }
    .hero-search { flex-direction: column; border-radius: 18px; }
    .hero-search button { width: 100%; }
  }
</style>
{% endblock %}

{% block body %}
  {% set images = [
    'birthday_photoshoot.jpg',
    'Character_design.PNG',
    'icon.jpg',
    'illustration.png',
    'Portrait.JPG',
    'Sunset.jpg'
  ] %}

  <section class="hero">
    <div class="hero-inner">
      <p class="lead" style="margin-bottom:0.5rem;font-size:0.95rem;letter-spacing:0.12em;text-transform:uppercase;opacity:0.92;">
        280,000+ style discovery
      </p>
      <h1>Commission <span>human artists</span></h1>
      <p class="lead">Browse open listings, preview artwork, and reach out when a style matches your vibe — inspired by VGen’s marketplace flow.</p>
      <form class="hero-search" method="get" action="{{ path('app_commissions_browse') }}" role="search">
        {% if categoryId > 0 %}
          <input type="hidden" name="category" value="{{ categoryId }}">
        {% endif %}
        <input type="search" name="q" value="{{ q|e }}" placeholder="Search vtuber, portrait, emotes…" aria-label="Search commissions">
        <button type="submit"><i class="bi bi-search"></i> Search</button>
      </form>
    </div>
  </section>

  <div class="browse-toolbar">
    <section class="filters reveal" aria-label="Commission filters">
      <div class="filters-top">
        <h2><i class="bi bi-funnel-fill"></i> Filter listings</h2>
        <span class="sort-pill">{{ commissions|length }} result{{ commissions|length == 1 ? '' : 's' }}{% if q %} for “{{ q }}”{% endif %}</span>
      </div>
      <div class="chip-row" aria-label="Categories">
        <a class="chip {{ categoryId == 0 ? 'active' : '' }}" href="{{ path('app_commissions_browse', q ? {q: q} : {}) }}">
          <i class="bi bi-grid-fill"></i> All
        </a>
        {% for category in categories %}
          <a class="chip {{ categoryId == category.id ? 'active' : '' }}"
             href="{{ path('app_commissions_browse', q ? {q: q, category: category.id} : {category: category.id}) }}">
            <i class="bi bi-tag-fill"></i> {{ category.name }}
          </a>
        {% endfor %}
      </div>
    </section>
  </div>

  <section class="section-block" style="padding-top:2.5rem;">
    <div class="page-section">
      <div class="sort-bar reveal">
        <span><i class="bi bi-sort-down"></i> Showing latest first</span>
        <span class="sort-pill">Trending</span>
        <span class="sort-pill">Open</span>
        <span class="sort-pill">Verified artists</span>
      </div>

      <div class="listing-grid reveal" aria-label="Commission listings" id="listings">
        {% for commission in commissions %}
          {% set img = images[loop.index0 % images|length] %}
          {% set rating = 4.5 + (loop.index0 % 5) * 0.1 %}
          <article class="listing-card">
            <div class="listing-thumb" style="background-image:url('{{ asset('commissions_images/' ~ img) }}');">
              <span class="badge-open">OPEN</span>
              <span class="badge-cat">{{ commission.category ? commission.category.name : 'General' }}</span>
            </div>
            <div class="listing-body">
              <h3 class="listing-title">{{ commission.title }}</h3>
              <div class="listing-rating">
                <i class="bi bi-star-fill"></i> {{ rating|number_format(1) }}
                <span style="color:var(--muted);">({{ 20 + loop.index * 7 }})</span>
              </div>
              {% if commission.description %}
                <p class="listing-desc">{{ commission.description }}</p>
              {% endif %}
              <div class="listing-meta">
                <span><i class="bi bi-person-circle"></i> {{ commission.artist ? commission.artist.name : 'Artist' }}</span>
                <span class="listing-price">₱{{ commission.price|number_format(2, '.', ',') }}</span>
              </div>
              <div class="listing-actions">
                <button
                  type="button"
                  class="btn-browse"
                  data-bs-toggle="modal"
                  data-bs-target="#commissionPreview"
                  data-preview-title="{{ commission.title|e('html_attr') }}"
                  data-preview-artist="{{ (commission.artist ? commission.artist.name : 'Artist')|e('html_attr') }}"
                  data-preview-category="{{ (commission.category ? commission.category.name : 'General')|e('html_attr') }}"
                  data-preview-price="₱{{ commission.price|number_format(2, '.', ',') }}"
                  data-preview-desc="{{ commission.description|default('No description yet.')|e('html_attr') }}"
                  data-preview-src="{{ asset('commissions_images/' ~ img) }}"
                >
                  <i class="bi bi-eye"></i> View
                </button>
                {% if app.user and commission.client and commission.client.id == app.user.id %}
                  <a class="btn-browse-solid" href="{{ path('app_account_progress') }}">
                    <i class="bi bi-clock-history"></i> Track progress
                  </a>
                {% elseif commission.client %}
                  <span class="btn-browse-solid" style="opacity:0.7;cursor:not-allowed;">
                    <i class="bi bi-lock-fill"></i> Reserved
                  </span>
                {% elseif app.user %}
                  <form method="post" action="{{ path('app_commission_request', {'id': commission.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('request_commission' ~ commission.id) }}">
                    <button type="submit" class="btn-browse-solid" style="border:0;">
                      <i class="bi bi-bag-heart-fill"></i> Request slot
                    </button>
                  </form>
                {% else %}
                  <a class="btn-browse-solid" href="{{ path('app_login') }}">
                    <i class="bi bi-box-arrow-in-right"></i> Login to request
                  </a>
                {% endif %}
              </div>
            </div>
          </article>
        {% else %}
          <div class="empty-state">
            <i class="bi bi-inbox" style="font-size:2.5rem;color:#7c3aed;"></i>
            <h3 style="margin:1rem 0 0.5rem;font-weight:900;color:#4b0082;">No commissions found</h3>
            <p style="margin:0 0 1rem;color:var(--muted);font-weight:650;">Try clearing filters or browse all categories.</p>
            <a href="{{ path('app_commissions_browse') }}" class="btn-hero" style="display:inline-flex;">View all listings</a>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <div class="page-section">
    <div class="stats-strip reveal">
      <div class="stat-card"><strong>{{ commissions|length }}</strong><span>Matching listings</span></div>
      <div class="stat-card"><strong>{{ categories|length }}</strong><span>Categories</span></div>
      <div class="stat-card"><strong>OPEN</strong><span>Slots available</span></div>
      <div class="stat-card"><strong>4.9★</strong><span>Avg. artist rating</span></div>
    </div>
  </div>

  <section class="section-block" style="background:linear-gradient(180deg, rgba(124,58,237,0.04), transparent);">
    <div class="page-section reveal">
      <div class="section-head">
        <div class="kicker"><i class="bi bi-hash"></i> Popular tags</div>
        <h2>Find your niche</h2>
      </div>
      <div class="tag-cloud">
        {% for tag in ['vtuber', 'ych', 'chibi', 'portrait', 'emotes', 'live2d', 'fanart', 'character design', 'stream assets', 'reference sheet'] %}
          <a href="{{ path('app_commissions_browse', {q: tag}) }}" class="tag">#{{ tag }}</a>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section-block">
    <div class="page-section reveal">
      <div class="section-head">
        <div class="kicker"><i class="bi bi-signpost-split"></i> How to order</div>
        <h2>From browse to inbox</h2>
      </div>
      <div class="steps">
        <div class="step-card"><div class="step-num">1</div><h3>Pick a listing</h3><p>Scroll the grid, use filters, or search by keyword.</p></div>
        <div class="step-card"><div class="step-num">2</div><h3>Preview</h3><p>Hit View for a full image preview — VGen-style modal.</p></div>
        <div class="step-card"><div class="step-num">3</div><h3>Request</h3><p>Choose Request slot so staff can reserve the commission for your account.</p></div>
        <div class="step-card"><div class="step-num">4</div><h3>Track</h3><p>Follow the artist’s progress from your account timeline until delivery.</p></div>
      </div>
    </div>
  </section>

  <section class="section-block" style="padding-top:0;">
    <div class="page-section reveal">
      <div class="section-head">
        <div class="kicker"><i class="bi bi-lightning-charge-fill"></i> More to explore</div>
        <h2>Trending open commissions</h2>
        <p>Swipe through featured picks — same artists, fresh angles.</p>
      </div>
      {% include 'public/_featured_commissions.html.twig' %}
    </div>
  </section>

  <section class="section-block">
    <div class="page-section reveal">
      <div class="section-head">
        <div class="kicker"><i class="bi bi-question-circle"></i> FAQ</div>
        <h2>Commission browsing questions</h2>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button type="button" class="faq-q">What does OPEN mean? <i class="bi bi-chevron-down"></i></button>
          <div class="faq-a">The artist is accepting new clients for that listing. Closed or paused slots won’t show OPEN.</div>
        </div>
        <div class="faq-item">
          <button type="button" class="faq-q">Can I filter by category? <i class="bi bi-chevron-down"></i></button>
          <div class="faq-a">Yes — tap a category chip above the grid. Combine with search for tighter results.</div>
        </div>
        <div class="faq-item">
          <button type="button" class="faq-q">How do I pay? <i class="bi bi-chevron-down"></i></button>
          <div class="faq-a">Payment details are arranged after your slot is reserved. The request button starts the commission flow; Contact is for questions.</div>
        </div>
        <div class="faq-item">
          <button type="button" class="faq-q">I’m an artist — how do I get listed? <i class="bi bi-chevron-down"></i></button>
          <div class="faq-a">Listings are managed by staff for now. Reach out via Contact to feature your work on the browse page.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-block" style="padding-bottom:5rem;">
    <div class="cta-band reveal">
      <h2>Found something you love?</h2>
      <p>Don’t scroll past it — preview the piece, request a slot, then track the artist’s progress from your account.</p>
      <a href="#listings" class="btn-hero"><i class="bi bi-arrow-up"></i> Back to listings</a>
      <a href="{{ path('app_contact') }}" class="btn-hero ghost">Ask a question</a>
    </div>
  </section>

  <div class="modal fade" id="commissionPreview" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
      <div class="modal-content" style="border-radius:20px;overflow:hidden;border:none;">
        <div class="modal-header" style="border:0;padding:1.25rem 1.25rem 0.5rem;">
          <div>
            <div id="previewCategory" class="text-muted" style="font-weight:900;font-size:0.9rem;"></div>
            <h5 id="previewTitle" class="modal-title" style="font-weight:900;color:#2a124b;margin:0;"></h5>
            <div style="font-weight:800;color:#5b5470;">
              <span id="previewArtist"></span> · <span id="previewPrice"></span>
            </div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" style="padding:0 1.25rem 1.25rem;">
          <div class="row g-3">
            <div class="col-12 col-lg-7">
              <div style="background:#0b0713;border-radius:16px;overflow:hidden;">
                <img id="previewImg" src="" alt="" style="width:100%;display:block;">
              </div>
            </div>
            <div class="col-12 col-lg-5">
              <div style="background:rgba(249,245,255,0.9);border:1px solid rgba(124,58,237,0.12);border-radius:16px;padding:1.25rem;">
                <div style="font-weight:900;color:#4b0082;margin-bottom:0.5rem;">About this listing</div>
                <p id="previewDesc" style="margin:0 0 1rem;color:#5b5470;font-weight:650;line-height:1.65;"></p>
                <p style="margin:0;color:#5b5470;font-weight:650;line-height:1.65;">Close this preview and use <strong>Request slot</strong> on the listing card to reserve it under your account.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}

{% block page_scripts %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  (function () {
    const previewModal = document.getElementById('commissionPreview');
    if (!previewModal) return;
    previewModal.addEventListener('show.bs.modal', function (event) {
      const button = event.relatedTarget;
      if (!button) return;
      document.getElementById('previewTitle').textContent = button.getAttribute('data-preview-title') || '';
      document.getElementById('previewArtist').textContent = button.getAttribute('data-preview-artist') || '';
      document.getElementById('previewCategory').textContent = button.getAttribute('data-preview-category') || '';
      document.getElementById('previewPrice').textContent = button.getAttribute('data-preview-price') || '';
      document.getElementById('previewDesc').textContent = button.getAttribute('data-preview-desc') || '';
      const img = document.getElementById('previewImg');
      img.src = button.getAttribute('data-preview-src') || '';
      img.alt = button.getAttribute('data-preview-title') || 'Commission preview';
    });
  })();
</script>
{% endblock %}
