<style>
  html { scroll-behavior: smooth; }

  :root {
    --purple-deep: #4b0082;
    --purple-main: #7c3aed;
    --purple-soft: #c084fc;
    --purple-bg: #f9f5ff;
    --ink: #2a124b;
    --muted: #5b5470;
    --card: rgba(255,255,255,0.94);
    --radius-lg: 22px;
    --shadow: 0 12px 32px rgba(124, 58, 237, 0.12);
  }

  * { box-sizing: border-box; }

  body {
    background: var(--purple-bg);
    font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
    margin: 0;
    padding: 0;
    color: var(--ink);
  }

  .page-section {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-block {
    padding: 4.5rem 0;
  }

  .section-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 2.25rem;
  }

  .section-head h2 {
    font-size: clamp(1.85rem, 3vw, 2.55rem);
    font-weight: 900;
    color: var(--purple-deep);
    margin: 0 0 0.65rem;
    letter-spacing: -0.02em;
  }

  .section-head p {
    margin: 0;
    color: var(--muted);
    font-weight: 650;
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.85rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    font-weight: 900;
    font-size: 0.88rem;
    color: var(--purple-deep);
    background: rgba(124, 58, 237, 0.08);
    border: 1px solid rgba(124, 58, 237, 0.18);
  }

  /* Navbar */
  .site-header {
    position: relative;
    z-index: 1000;
  }

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 0.85rem clamp(1rem, 3vw, 2rem);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    transition: background-color 0.25s ease, box-shadow 0.25s ease, padding 0.25s ease;
  }

  .navbar.solid,
  .navbar.scrolled,
  .navbar.menu-open {
    background: rgba(255,255,255,0.96);
    box-shadow: 0 14px 40px rgba(42, 18, 75, 0.1);
    backdrop-filter: blur(18px);
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    min-width: 0;
    text-decoration: none;
    border-radius: 999px;
    padding: 0.15rem 0.25rem;
  }

  .brand-logo {
    height: 48px;
    width: 132px;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 8px 14px rgba(42, 18, 75, 0.22));
  }

  .landing-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    flex: 1;
    max-width: fit-content;
    padding: 0.3rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.14);
    border: 1px solid rgba(255,255,255,0.24);
    backdrop-filter: blur(12px);
  }

  .landing-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.56rem 0.8rem;
    border-radius: 999px;
    color: #fff;
    font-weight: 900;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.15s ease, background 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
  }

  .landing-link:hover {
    transform: translateY(-1px);
    background: rgba(255,255,255,0.24);
    box-shadow: 0 10px 25px rgba(124, 58, 237, 0.14);
    color: #fff;
  }

  .landing-link.active {
    background: rgba(255,255,255,0.3);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.2);
  }

  .navbar.solid .landing-nav,
  .navbar.scrolled .landing-nav,
  .navbar.menu-open .landing-nav {
    background: rgba(124,58,237,0.06);
    border-color: rgba(124,58,237,0.16);
  }

  .navbar.solid .landing-link,
  .navbar.scrolled .landing-link,
  .navbar.menu-open .landing-link {
    color: var(--purple-deep);
  }

  .navbar.solid .landing-link:hover,
  .navbar.scrolled .landing-link:hover,
  .navbar.menu-open .landing-link:hover {
    background: rgba(124,58,237,0.1);
    color: var(--purple-main);
  }

  .navbar.solid .landing-link.active,
  .navbar.scrolled .landing-link.active,
  .navbar.menu-open .landing-link.active {
    background: rgba(124,58,237,0.15);
    color: var(--purple-main);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.6rem;
  }

  .nav-pill,
  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.42rem;
    border-radius: 999px;
    padding: 0.58rem 0.9rem;
    font-weight: 950;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .nav-pill {
    color: var(--purple-deep);
    background: rgba(255,255,255,0.92);
    border: 1px solid rgba(255,255,255,0.56);
  }

  .nav-pill:hover {
    transform: translateY(-1px);
    color: var(--purple-main);
    box-shadow: 0 12px 28px rgba(42, 18, 75, 0.14);
  }

  .nav-cta {
    color: #fff;
    background: linear-gradient(135deg, #7c3aed, #c084fc);
    border: 1px solid rgba(255,255,255,0.2);
    box-shadow: 0 12px 28px rgba(124, 58, 237, 0.24);
  }

  .nav-cta:hover {
    transform: translateY(-1px);
    color: #fff;
    box-shadow: 0 14px 34px rgba(124, 58, 237, 0.32);
  }

  .nav-cta.muted {
    background: #fff;
    color: var(--purple-main);
    border-color: rgba(124,58,237,0.18);
    box-shadow: none;
  }

  .mobile-nav-actions {
    display: none;
  }

  .nav-toggle {
    display: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    border: 1px solid rgba(255,255,255,0.34);
    border-radius: 14px;
    background: rgba(255,255,255,0.16);
    cursor: pointer;
  }

  .nav-toggle span {
    width: 20px;
    height: 2px;
    border-radius: 999px;
    background: #fff;
    transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease;
  }

  .navbar.solid .nav-toggle,
  .navbar.scrolled .nav-toggle,
  .navbar.menu-open .nav-toggle {
    background: rgba(124,58,237,0.07);
    border-color: rgba(124,58,237,0.18);
  }

  .navbar.solid .nav-toggle span,
  .navbar.scrolled .nav-toggle span,
  .navbar.menu-open .nav-toggle span {
    background: var(--purple-deep);
  }

  .nav-toggle.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.active span:nth-child(2) { opacity: 0; }
  .nav-toggle.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 2px solid rgba(255,255,255,0.88);
    border-radius: 50%;
    background: #fff;
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  .navbar.solid .avatar,
  .navbar.scrolled .avatar,
  .navbar.menu-open .avatar {
    border-color: var(--purple-main);
  }

  .avatar:hover,
  .avatar[aria-expanded="true"] {
    transform: translateY(-1px) scale(1.03);
    box-shadow: 0 12px 28px rgba(42, 18, 75, 0.16);
  }

  .dropdown { position: relative; }

  .dropdown-content {
    display: none;
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    margin: 0;
    list-style: none;
    background: #fff;
    border: 1px solid rgba(124,58,237,0.12);
    border-radius: 18px;
    box-shadow: 0 18px 45px rgba(42, 18, 75, 0.16);
    padding: 0.55rem;
    min-width: 240px;
    z-index: 1001;
  }

  .dropdown-content.show { display: block; }

  .dropdown-content a {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.75rem 0.9rem;
    color: #33204f;
    text-decoration: none;
    border-radius: 12px;
    font-weight: 850;
    transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }

  .dropdown-content a:hover {
    background: var(--purple-bg);
    color: var(--purple-main);
    transform: translateX(2px);
  }

  /* Hero */
  .hero {
    text-align: center;
    padding: 10.5rem 1.5rem 5rem;
    background: linear-gradient(135deg, #ebd3fe, #c084fc 55%, #a855f7);
    color: #fff;
    border-radius: 0 0 56px 56px;
    box-shadow: var(--shadow);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: -40%;
    background: radial-gradient(circle at 50% 0%, rgba(255,255,255,0.28), transparent 55%);
    pointer-events: none;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 12% 30%, rgba(255,255,255,0.35) 0 2px, transparent 3px),
      radial-gradient(circle at 72% 22%, rgba(255,255,255,0.28) 0 2px, transparent 3px),
      radial-gradient(circle at 48% 68%, rgba(255,255,255,0.2) 0 2px, transparent 3px);
    opacity: 0.85;
    pointer-events: none;
  }

  .hero-inner { position: relative; z-index: 1; max-width: 920px; margin: 0 auto; }

  .hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.65rem);
    font-weight: 900;
    line-height: 1.08;
    margin: 0 0 1rem;
    letter-spacing: -0.03em;
  }

  .hero h1 span { color: #f3e8ff; }

  .hero .lead {
    font-size: clamp(1.05rem, 2vw, 1.28rem);
    font-weight: 800;
    max-width: 720px;
    margin: 0 auto 0.65rem;
    line-height: 1.65;
    opacity: 0.98;
  }

  .hero .sub {
    font-size: 1.05rem;
    max-width: 680px;
    margin: 0 auto 1.5rem;
    line-height: 1.75;
    font-weight: 650;
    opacity: 0.92;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .btn-hero {
    background: #fff;
    color: var(--purple-main);
    font-weight: 900;
    border: none;
    border-radius: 999px;
    padding: 0.95rem 1.45rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 12px 28px rgba(0,0,0,0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn-hero:hover { transform: translateY(-2px); box-shadow: 0 16px 36px rgba(0,0,0,0.14); color: var(--purple-main); }
  .btn-hero.ghost {
    background: rgba(255,255,255,0.16);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.38);
    box-shadow: none;
  }
  .btn-hero.ghost:hover { background: rgba(255,255,255,0.26); color: #fff; }

  /* Stats strip */
  .stats-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: -2.5rem;
    position: relative;
    z-index: 2;
    padding-bottom: 0.5rem;
  }

  .stat-card {
    background: var(--card);
    border-radius: 18px;
    padding: 1.35rem 1rem;
    text-align: center;
    border: 1px solid rgba(124,58,237,0.12);
    box-shadow: 0 8px 24px rgba(124,58,237,0.08);
  }

  .stat-card strong {
    display: block;
    font-size: clamp(1.35rem, 2.5vw, 1.85rem);
    font-weight: 900;
    color: var(--purple-deep);
    line-height: 1.1;
  }

  .stat-card span {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.88rem;
    font-weight: 750;
    color: var(--muted);
  }

  /* Pillars */
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .pillar-card {
    background: var(--card);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.5rem;
    border: 1px solid rgba(124,58,237,0.1);
    box-shadow: 0 8px 22px rgba(0,0,0,0.04);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    position: relative;
    overflow: hidden;
  }

  .pillar-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--purple-main), var(--purple-soft));
  }

  .pillar-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow);
  }

  .pillar-icon {
    width: 52px;
    height: 52px;
    border-radius: 16px;
    background: linear-gradient(135deg, #ebd3fe, #c084fc);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    color: var(--purple-deep);
    margin-bottom: 1rem;
  }

  .pillar-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    font-weight: 900;
    color: var(--ink);
  }

  .pillar-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
    font-weight: 650;
    font-size: 0.98rem;
  }

  /* Categories */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.85rem;
  }

  .category-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    padding: 1.1rem 0.75rem;
    background: var(--card);
    border-radius: 18px;
    border: 1px solid rgba(124,58,237,0.1);
    text-decoration: none;
    color: var(--ink);
    font-weight: 850;
    font-size: 0.88rem;
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .category-pill:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(124,58,237,0.12);
    border-color: rgba(124,58,237,0.28);
    color: var(--purple-deep);
  }

  .category-pill i {
    font-size: 1.5rem;
    color: var(--purple-main);
  }

  /* Commission cards */
  .commission-scroll {
    display: flex;
    gap: 1.1rem;
    overflow-x: auto;
    padding: 0.5rem 0 1.25rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--purple-soft) transparent;
  }

  .commission-card {
    flex: 0 0 280px;
    scroll-snap-align: start;
    background: var(--card);
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(124,58,237,0.1);
    box-shadow: 0 8px 22px rgba(0,0,0,0.05);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .commission-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow);
  }

  .commission-thumb {
    height: 200px;
    background-size: cover;
    background-position: center;
    position: relative;
  }

  .badge-open {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #10b981;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    padding: 0.3rem 0.55rem;
    border-radius: 8px;
  }

  .commission-body { padding: 1rem 1.1rem 1.15rem; }

  .commission-body h3 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    font-weight: 900;
    color: var(--ink);
    line-height: 1.35;
  }

  .commission-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 800;
  }

  .rating { color: #f59e0b; }
  .price { color: var(--purple-main); }

  /* Steps */
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    counter-reset: step;
  }

  .step-card {
    background: var(--card);
    border-radius: 18px;
    padding: 1.5rem 1.25rem;
    border: 1px solid rgba(124,58,237,0.1);
    position: relative;
  }

  .step-num {
    width: 36px;
    height: 36px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--purple-main), var(--purple-soft));
    color: #fff;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.85rem;
    font-size: 0.95rem;
  }

  .step-card h3 { margin: 0 0 0.4rem; font-size: 1.05rem; font-weight: 900; color: var(--purple-deep); }
  .step-card p { margin: 0; color: var(--muted); font-weight: 650; line-height: 1.65; font-size: 0.95rem; }

  /* Testimonials */
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .testimonial {
    background: var(--card);
    border-radius: 20px;
    padding: 1.5rem;
    border: 1px solid rgba(124,58,237,0.1);
    box-shadow: 0 6px 18px rgba(0,0,0,0.04);
  }

  .testimonial .stars { color: #f59e0b; margin-bottom: 0.75rem; font-size: 0.95rem; }
  .testimonial blockquote {
    margin: 0 0 1rem;
    font-weight: 650;
    line-height: 1.7;
    color: var(--muted);
    font-style: normal;
  }

  .testimonial .who {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 900;
    color: var(--purple-deep);
  }

  .testimonial .who .ava {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ebd3fe, #c084fc);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
  }

  /* Tags */
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .tag {
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(124,58,237,0.08);
    border: 1px solid rgba(124,58,237,0.14);
    color: var(--purple-deep);
    font-weight: 800;
    font-size: 0.86rem;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .tag:hover {
    background: rgba(124,58,237,0.16);
    transform: translateY(-1px);
    color: var(--purple-deep);
  }

  /* CTA band */
  .cta-band {
    background: linear-gradient(135deg, #7c3aed, #c084fc);
    border-radius: 28px;
    padding: 3rem 2rem;
    text-align: center;
    color: #fff;
    box-shadow: var(--shadow);
    margin: 0 1.5rem;
    max-width: calc(1180px - 3rem);
    margin-left: auto;
    margin-right: auto;
  }

  .cta-band h2 {
    margin: 0 0 0.65rem;
    font-size: clamp(1.65rem, 3vw, 2.35rem);
    font-weight: 900;
  }

  .cta-band p {
    margin: 0 auto 1.35rem;
    max-width: 560px;
    font-weight: 700;
    opacity: 0.95;
    line-height: 1.7;
  }

  .cta-band .btn-hero { margin: 0 0.35rem; }

  /* Team */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.35rem;
  }

  .team-card {
    background: var(--card);
    border-radius: 20px;
    padding: 1.75rem 1.35rem;
    text-align: center;
    border: 1px solid rgba(124,58,237,0.1);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .team-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow);
  }

  .team-ava {
    width: 88px;
    height: 88px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 10px 24px rgba(124,58,237,0.18);
    border: 3px solid #fff;
  }

  .team-ava img { width: 100%; height: 100%; object-fit: cover; }

  .team-name { font-weight: 900; color: var(--purple-deep); font-size: 1.15rem; margin-bottom: 0.25rem; }
  .team-role { color: var(--muted); font-weight: 700; margin-bottom: 0.65rem; }
  .team-bio { font-size: 0.92rem; color: var(--muted); line-height: 1.65; font-weight: 650; margin: 0; }

  /* Two column story */
  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
  }

  .story-card {
    background: var(--card);
    border-radius: var(--radius-lg);
    padding: 2rem;
    border: 1px solid rgba(124,58,237,0.1);
    box-shadow: 0 8px 24px rgba(0,0,0,0.04);
  }

