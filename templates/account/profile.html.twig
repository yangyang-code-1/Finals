{% extends 'public/layout.html.twig' %}

{% block title %}My profile — Comms{% endblock %}

{% block page_styles %}
<style>
  .profile-shell { max-width: 1180px; margin: 0 auto; padding: 7rem 1.25rem 4rem; }
  .profile-hero {
    background: #fff;
    border-radius: 30px;
    overflow: hidden;
    border: 1px solid rgba(124,58,237,0.12);
    box-shadow: 0 24px 70px rgba(42,18,75,0.1);
  }
  .profile-cover {
    min-height: 210px;
    background:
      radial-gradient(circle at 15% 20%, rgba(255,255,255,0.35), transparent 28%),
      linear-gradient(135deg, #4b0082, #7c3aed 55%, #c084fc);
    position: relative;
  }
  .profile-cover::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px), linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 34px 34px;
    opacity: 0.35;
  }
  .profile-main {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: end;
    padding: 0 1.5rem 1.5rem;
    margin-top: -58px;
    position: relative;
    z-index: 1;
  }
  .profile-avatar {
    width: 120px;
    height: 120px;
    border-radius: 32px;
    padding: 6px;
    background: #fff;
    box-shadow: 0 18px 45px rgba(42,18,75,0.18);
  }
  .profile-avatar img { width: 100%; height: 100%; border-radius: 26px; object-fit: cover; }
  .profile-title h1 { margin: 0; font-size: clamp(1.8rem, 4vw, 2.7rem); font-weight: 950; color: #2a124b; letter-spacing: -0.04em; }
  .profile-title p { margin: 0.25rem 0 0; color: #6b5f80; font-weight: 750; }
  .profile-badges { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }
  .profile-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    background: rgba(124,58,237,0.08);
    color: #5b21b6;
    font-weight: 900;
    font-size: 0.82rem;
  }
  .profile-actions { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 0.65rem; }
  .profile-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.72rem 1rem;
    border-radius: 999px;
    font-weight: 900;
    text-decoration: none;
    border: 1px solid rgba(124,58,237,0.18);
  }
  .profile-btn.primary { background: linear-gradient(135deg, #7c3aed, #c084fc); color: #fff; box-shadow: 0 14px 35px rgba(124,58,237,0.24); }
  .profile-btn.soft { background: #fff; color: #4b0082; }
  .profile-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 1.25rem; margin-top: 1.25rem; }
  .profile-card {
    background: #fff;
    border: 1px solid rgba(124,58,237,0.12);
    border-radius: 24px;
    padding: 1.25rem;
    box-shadow: 0 18px 50px rgba(42,18,75,0.07);
  }
  .profile-card h2 { margin: 0 0 1rem; font-size: 1.1rem; font-weight: 950; color: #2a124b; }
  .profile-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
  .profile-stat { padding: 1rem; border-radius: 18px; background: #f9f5ff; border: 1px solid rgba(124,58,237,0.1); }
  .profile-stat strong { display: block; font-size: 1.7rem; font-weight: 950; color: #4b0082; }
  .profile-stat span { color: #6b5f80; font-weight: 800; font-size: 0.84rem; }
  .info-list { display: grid; gap: 0.75rem; }
  .info-row { display: flex; justify-content: space-between; gap: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid #f1edf8; }
  .info-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .info-label { color: #7a6d91; font-weight: 850; }
  .info-value { color: #2a124b; font-weight: 900; text-align: right; word-break: break-word; }
  .mini-feed { display: grid; gap: 0.75rem; }
  .feed-item { display: flex; gap: 0.85rem; padding: 0.9rem; border-radius: 18px; background: #fbf9ff; border: 1px solid rgba(124,58,237,0.08); }
  .feed-icon { width: 42px; height: 42px; border-radius: 14px; display: grid; place-items: center; background: rgba(124,58,237,0.12); color: #7c3aed; flex: none; }
  .feed-item strong { display: block; color: #2a124b; }
  .feed-item span { color: #6b5f80; font-weight: 700; font-size: 0.9rem; }
  .empty-profile { max-width: 720px; margin: 7rem auto 4rem; padding: 1.25rem; }
  @media (max-width: 900px) {
    .profile-main { grid-template-columns: 1fr; align-items: start; }
    .profile-actions { justify-content: flex-start; }
    .profile-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .profile-shell { padding-top: 6rem; }
    .profile-main { margin-top: -46px; padding: 0 1rem 1.25rem; }
    .profile-avatar { width: 96px; height: 96px; border-radius: 26px; }
    .profile-avatar img { border-radius: 20px; }
    .profile-stats { grid-template-columns: 1fr; }
    .info-row { flex-direction: column; }
    .info-value { text-align: left; }
  }
</style>
{% endblock %}

{% block body %}
{% if app.user %}
  {% set activeProgress = client_commissions|length %}

  <main class="profile-shell">
    <section class="profile-hero">
      <div class="profile-cover"></div>
      <div class="profile-main">
        <div class="profile-avatar">
          <img src="{{ asset('PROFILE.png') }}" alt="">
        </div>
        <div class="profile-title">
          <h1>{{ app.user.name|default('Your profile') }}</h1>
          <p>{{ app.user.email }}</p>
          <div class="profile-badges">
            <span class="profile-badge"><i class="bi bi-person-heart"></i> {{ app.user.role|replace({'ROLE_': ''})|title }}</span>
            <span class="profile-badge"><i class="bi bi-shield-check"></i> {{ app.user.isVerified ? 'Verified email' : 'Needs verification' }}</span>
            {% if app.user.createdAt %}
              <span class="profile-badge"><i class="bi bi-calendar-heart"></i> Since {{ app.user.createdAt|date('M Y') }}</span>
            {% endif %}
          </div>
        </div>
        <div class="profile-actions">
          <a href="{{ path('app_account_progress') }}" class="profile-btn primary"><i class="bi bi-clock-history"></i> View progress</a>
          <a href="{{ path('app_commissions_browse') }}" class="profile-btn soft"><i class="bi bi-palette-fill"></i> Browse</a>
          {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_admin_dashboard') }}" class="profile-btn soft"><i class="bi bi-speedometer2"></i> Admin</a>
          {% elseif is_granted('ROLE_STAFF') %}
            <a href="{{ path('app_commission_index') }}" class="profile-btn soft"><i class="bi bi-kanban"></i> Staff</a>
          {% endif %}
        </div>
      </div>
    </section>

    <div class="profile-grid">
      <section class="profile-card">
        <h2><i class="bi bi-graph-up-arrow me-1"></i> Commission snapshot</h2>
        <div class="profile-stats">
          <div class="profile-stat"><strong>{{ activeProgress }}</strong><span>Requested</span></div>
          <div class="profile-stat"><strong>{{ completed_commissions_count|default(0) }}</strong><span>Completed</span></div>
          <div class="profile-stat"><strong>{{ artist_commissions|length }}</strong><span>Artist listings</span></div>
        </div>
      </section>

      <section class="profile-card">
        <h2><i class="bi bi-person-vcard me-1"></i> Profile details</h2>
        <div class="info-list">
          <div class="info-row"><span class="info-label">Full name</span><span class="info-value">{{ app.user.name|default('Not set') }}</span></div>
          <div class="info-row"><span class="info-label">Email</span><span class="info-value">{{ app.user.email }}</span></div>
          <div class="info-row"><span class="info-label">Account status</span><span class="info-value">{{ app.user.isVerified ? 'Verified' : 'Unverified' }}</span></div>
        </div>
      </section>

      <section class="profile-card">
        <h2><i class="bi bi-clock-history me-1"></i> Latest progress</h2>
        <div class="mini-feed">
          {% for commission in client_commissions|slice(0, 4) %}
            <div class="feed-item">
              <div class="feed-icon"><i class="bi bi-brush"></i></div>
              <div>
                <strong>{{ commission.title }}</strong>
                <span>{{ commission.artist ? commission.artist.name : 'Artist pending' }} · {{ commission.status }}</span>
              </div>
            </div>
          {% else %}
            <div class="feed-item">
              <div class="feed-icon"><i class="bi bi-stars"></i></div>
              <div>
                <strong>No active commission yet</strong>
                <span>Browse open listings and request a slot to start tracking artist progress.</span>
              </div>
            </div>
          {% endfor %}
        </div>
      </section>

      <section class="profile-card">
        <h2><i class="bi bi-lightning-charge me-1"></i> Quick actions</h2>
        <div class="mini-feed">
          <a class="feed-item text-decoration-none" href="{{ path('app_account_progress') }}">
            <div class="feed-icon"><i class="bi bi-signpost-split"></i></div>
            <div><strong>Progress timeline</strong><span>See each requested commission and current artist status.</span></div>
          </a>
          <a class="feed-item text-decoration-none" href="{{ path('app_contact') }}">
            <div class="feed-icon"><i class="bi bi-question-circle"></i></div>
            <div><strong>Ask a question</strong><span>Use Contact for questions, not for starting a commission request.</span></div>
          </a>
          <a class="feed-item text-decoration-none" href="{{ path('app_logout') }}">
            <div class="feed-icon"><i class="bi bi-box-arrow-right"></i></div>
            <div><strong>Log out</strong><span>End this browser session.</span></div>
          </a>
        </div>
      </section>
    </div>
  </main>
{% else %}
  <div class="empty-profile">
    <div class="profile-card">
      <h1 style="font-weight:950;color:#2a124b;">Your Comms profile</h1>
      <p style="color:#6b5f80;font-weight:750;">Sign in to view your social-style profile, requested commissions, and artist progress timeline.</p>
      <div class="profile-actions" style="justify-content:flex-start;">
        <a href="{{ path('app_login') }}" class="profile-btn primary">Log in</a>
        <a href="{{ path('app_register') }}" class="profile-btn soft">Register</a>
      </div>
    </div>
  </div>
{% endif %}
{% endblock %}
