{% extends 'public/layout.html.twig' %}

{% block title %}My commission progress — Comms{% endblock %}

{% block page_styles %}
<style>
  .progress-shell { max-width: 1180px; margin: 0 auto; padding: 7rem 1.25rem 4rem; }
  .progress-hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-radius: 32px;
    color: #fff;
    background:
      radial-gradient(circle at 85% 20%, rgba(255,255,255,0.28), transparent 24%),
      linear-gradient(135deg, #4b0082, #7c3aed 58%, #c084fc);
    box-shadow: 0 26px 70px rgba(42,18,75,0.18);
    overflow: hidden;
  }
  .progress-hero h1 { margin: 0; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 950; letter-spacing: -0.04em; }
  .progress-hero p { max-width: 680px; margin: 0.75rem 0 0; color: rgba(255,255,255,0.9); font-weight: 750; line-height: 1.7; }
  .progress-hero-art {
    width: 130px;
    height: 130px;
    border-radius: 34px;
    display: grid;
    place-items: center;
    background: rgba(255,255,255,0.16);
    border: 1px solid rgba(255,255,255,0.24);
    font-size: 3rem;
  }
  .progress-grid { display: grid; gap: 1rem; margin-top: 1.25rem; }
  .progress-card {
    background: #fff;
    border: 1px solid rgba(124,58,237,0.12);
    border-radius: 26px;
    padding: 1.25rem;
    box-shadow: 0 18px 50px rgba(42,18,75,0.08);
  }
  .progress-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: start;
    margin-bottom: 1rem;
  }
  .progress-head h2 { margin: 0; font-size: 1.25rem; font-weight: 950; color: #2a124b; }
  .progress-meta { display: flex; flex-wrap: wrap; gap: 0.55rem; margin-top: 0.55rem; color: #6b5f80; font-weight: 780; font-size: 0.9rem; }
  .progress-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(124,58,237,0.08);
    color: #5b21b6;
    font-weight: 900;
    white-space: nowrap;
  }
  .timeline {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
    position: relative;
  }
  .timeline-step {
    padding: 1rem;
    border-radius: 20px;
    background: #fbf9ff;
    border: 1px solid rgba(124,58,237,0.1);
    color: #756985;
    min-height: 132px;
  }
  .timeline-step.done {
    background: linear-gradient(135deg, rgba(16,185,129,0.12), rgba(52,211,153,0.08));
    border-color: rgba(16,185,129,0.22);
    color: #065f46;
  }
  .timeline-step.current {
    background: linear-gradient(135deg, rgba(124,58,237,0.14), rgba(192,132,252,0.12));
    border-color: rgba(124,58,237,0.3);
    color: #4b0082;
    box-shadow: inset 0 0 0 1px rgba(124,58,237,0.08);
  }
  .timeline-step.cancelled {
    background: linear-gradient(135deg, rgba(239,68,68,0.12), rgba(248,113,113,0.08));
    border-color: rgba(239,68,68,0.2);
    color: #991b1b;
  }
  .step-dot {
    width: 42px;
    height: 42px;
    border-radius: 15px;
    display: grid;
    place-items: center;
    background: rgba(124,58,237,0.1);
    margin-bottom: 0.7rem;
    font-size: 1.2rem;
  }
  .timeline-step h3 { margin: 0 0 0.35rem; font-size: 1rem; font-weight: 950; }
  .timeline-step p { margin: 0; font-size: 0.88rem; font-weight: 700; line-height: 1.5; }
  .empty-progress {
    margin-top: 1.25rem;
    padding: 2rem;
    border-radius: 28px;
    background: #fff;
    border: 1px dashed rgba(124,58,237,0.28);
    text-align: center;
    box-shadow: 0 18px 50px rgba(42,18,75,0.06);
  }
  .empty-progress i { font-size: 3rem; color: #7c3aed; }
  .progress-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 1rem; }
  .progress-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    font-weight: 900;
    text-decoration: none;
  }
  .progress-btn.primary { color: #fff; background: linear-gradient(135deg, #7c3aed, #c084fc); }
  .progress-btn.soft { color: #4b0082; background: #f3e8ff; }
  @media (max-width: 820px) {
    .progress-hero { grid-template-columns: 1fr; }
    .progress-hero-art { display: none; }
    .progress-head { grid-template-columns: 1fr; }
    .timeline { grid-template-columns: 1fr; }
  }
</style>
{% endblock %}

{% block body %}
<main class="progress-shell">
  <section class="progress-hero">
    <div>
      <div class="kicker" style="background:rgba(255,255,255,0.16);border-color:rgba(255,255,255,0.22);color:#fff;">
        <i class="bi bi-clock-history"></i> Client timeline
      </div>
      <h1>My commission progress</h1>
      <p>Track the artist’s progress after you request a slot. Staff updates the status from the web dashboard, and this timeline shows where your commission currently is.</p>
    </div>
    <div class="progress-hero-art"><i class="bi bi-signpost-split-fill"></i></div>
  </section>

  {% if not app.user %}
    <div class="empty-progress">
      <i class="bi bi-person-lock"></i>
      <h2 style="font-weight:950;color:#2a124b;margin-top:0.75rem;">Log in to see your timeline</h2>
      <p style="color:#6b5f80;font-weight:750;">Your progress page is private to your account.</p>
      <div class="progress-actions">
        <a href="{{ path('app_login') }}" class="progress-btn primary">Log in</a>
        <a href="{{ path('app_register') }}" class="progress-btn soft">Register</a>
      </div>
    </div>
  {% elseif commissions|length == 0 %}
    <div class="empty-progress">
      <i class="bi bi-palette"></i>
      <h2 style="font-weight:950;color:#2a124b;margin-top:0.75rem;">No requested commissions yet</h2>
      <p style="color:#6b5f80;font-weight:750;">Browse open listings, preview an artist’s work, then request a slot. Contact is only for questions.</p>
      <div class="progress-actions">
        <a href="{{ path('app_commissions_browse') }}" class="progress-btn primary"><i class="bi bi-palette-fill"></i> Browse commissions</a>
        <a href="{{ path('app_contact') }}" class="progress-btn soft"><i class="bi bi-question-circle"></i> Ask a question</a>
      </div>
    </div>
  {% else %}
    <div class="progress-grid">
      {% for commission in commissions %}
        {% set status = commission.status|default('Pending') %}
        {% set statusIndex = status == 'Completed' ? 3 : (status == 'In Progress' ? 2 : (status == 'Cancelled' ? 0 : 1)) %}
        <article class="progress-card">
          <div class="progress-head">
            <div>
              <h2>{{ commission.title }}</h2>
              <div class="progress-meta">
                <span><i class="bi bi-person-badge"></i> {{ commission.artist ? commission.artist.name : 'Artist pending' }}</span>
                <span><i class="bi bi-folder2"></i> {{ commission.category ? commission.category.name : 'General' }}</span>
                <span><i class="bi bi-cash-coin"></i> ₱{{ commission.price|number_format(2, '.', ',') }}</span>
              </div>
            </div>
            <span class="progress-pill"><i class="bi bi-activity"></i> {{ status }}</span>
          </div>

          {% if status == 'Cancelled' %}
            <div class="timeline">
              <div class="timeline-step cancelled">
                <div class="step-dot"><i class="bi bi-x-circle"></i></div>
                <h3>Cancelled</h3>
                <p>This commission is no longer active. You can request another available slot from the browse page.</p>
              </div>
            </div>
          {% else %}
            <div class="timeline">
              {% for step in timeline_steps %}
                {% set stepNumber = loop.index %}
                {% set stepClass = stepNumber < statusIndex ? 'done' : (stepNumber == statusIndex ? 'current' : '') %}
                <div class="timeline-step {{ stepClass }}">
                  <div class="step-dot">
                    {% if stepNumber < statusIndex %}
                      <i class="bi bi-check2"></i>
                    {% elseif stepNumber == statusIndex %}
                      <i class="bi bi-brush"></i>
                    {% else %}
                      <i class="bi bi-circle"></i>
                    {% endif %}
                  </div>
                  <h3>{{ step }}</h3>
                  {% if step == 'Pending' %}
                    <p>Your request is recorded. Staff or the artist confirms the slot and project details.</p>
                  {% elseif step == 'In Progress' %}
                    <p>The artist is working on the commission. Check back here after staff updates the status.</p>
                  {% else %}
                    <p>The commission is finished and ready for final delivery or handoff.</p>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}
</main>
{% endblock %}
